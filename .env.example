# ==========================================
# BEARS WEEK 2026 - ENVIRONMENT VARIABLES
# ==========================================

# ==========================================
# APPLICATION
# ==========================================
APP_NAME="Bears Week 2026"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://bearssitges.com

# ==========================================
# DATABASE (PostgreSQL)
# ==========================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=ecommerce_db
DB_USER=bweek_admin
DB_USERNAME=bweek_admin
DB_PASSWORD=changeme_secure_password

# ==========================================
# REDIS
# ==========================================
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# ==========================================
# N8N
# ==========================================
N8N_API_URL=http://n8n:5678
N8N_API_TOKEN=changeme_n8n_api_token_min_32_chars
N8N_ENCRYPTION_KEY=changeme_n8n_encryption_key_min_32_chars
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme_n8n_password
N8N_DB=n8n_db
N8N_HOST=n8n

# ==========================================
# JWT AUTHENTICATION
# ==========================================
JWT_SECRET=changeme_jwt_secret_min_32_chars
JWT_TTL=30
JWT_REFRESH_TTL=20160
JWT_ALGO=HS256

# ==========================================
# MAIL
# ==========================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@bearssitges.com
MAIL_FROM_NAME="Bears Week 2026"

# ==========================================
# OPENAI (Para traducción automática)
# ==========================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4

# ==========================================
# WHATSAPP BUSINESS API
# ==========================================
WHATSAPP_PROVIDER=twilio
WHATSAPP_ACCOUNT_SID=your-twilio-account-sid
WHATSAPP_AUTH_TOKEN=your-twilio-auth-token
WHATSAPP_PHONE_NUMBER=+34612345678

# ==========================================
# TELEGRAM BOT
# ==========================================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_BOT_USERNAME=BearsWeekBot

# ==========================================
# GOOGLE WORKSPACE (Service Account)
# ==========================================
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}'

# ==========================================
# PAYMENT GATEWAYS
# ==========================================
STRIPE_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret

# ==========================================
# STORAGE
# ==========================================
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ==========================================
# LOGGING
# ==========================================
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ==========================================
# BROADCASTING
# ==========================================
BROADCAST_DRIVER=log
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# ==========================================
# VITE (Frontend Build)
# ==========================================
VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ==========================================
# LOCALIZATION
# ==========================================
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES
APP_TIMEZONE=Europe/Madrid

# ==========================================
# SECURITY
# ==========================================
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ==========================================
# CORE USERS (cuentas fijas protegidas)
# ==========================================
BSW_FIXED_USER_EMAIL=user@example.com
BSW_FIXED_ADMIN_EMAIL=admin@example.com
BSW_FIXED_SUPERADMIN_EMAIL_1=superadmin@example.com
BSW_FIXED_SUPERADMIN_EMAIL_2=
BSW_FIXED_USERS_PASSWORD=changeme_fixed_users_password

# ==========================================
# RATE LIMITING (Chatbot)
# ==========================================
CHATBOT_RATE_LIMIT_WEB=60
CHATBOT_RATE_LIMIT_WHATSAPP=30
CHATBOT_RATE_LIMIT_TELEGRAM=40
CHATBOT_RATE_LIMIT_ADMIN=120

# ==========================================
# SCRAPING
# ==========================================
SCRAPING_SOURCE_URL=https://bearssitges.org/bears-sitges-week/
SCRAPING_USER_AGENT="Mozilla/5.0 (compatible; BearsSitgesMigration/1.0)"
